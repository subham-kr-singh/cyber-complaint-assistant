# Server
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed browser origins for CORS.
# Example: http://localhost:5173,https://cybersetu.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,https://cybersetu.vercel.app

# Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/cybercomplaint

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Gemini AI (crime classification)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary (evidence file storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
